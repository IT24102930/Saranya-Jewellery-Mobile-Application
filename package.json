{
  "name": "saranya-minimal-starter",
  "version": "1.0.0",
  "description": "Minimal app: MongoDB connection + index page on port 3000",
  "private": true,
  "scripts": {
    "dev": "node backend/server.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "backend:dev": "node backend/server.js",
    "start": "node backend/server.js",
    "frontend:install": "npm --prefix frontend install",
    "mobile:install": "npm --prefix mobile install",
    "mobile:start": "npm --prefix mobile run start",
    "frontend:build": "npm --prefix frontend run build",
    "build": "npm --prefix frontend install && npm run frontend:build",
    "start:mern": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "^1.7.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cloudinary": "^2.9.0",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mongoose": "^9.1.5",
    "multer": "^2.1.0",
    "nodemailer": "^8.0.1",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
